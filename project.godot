; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Legends Open RPG"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SpriteGenerator="*res://scripts/autoloads/sprite_generator.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
CombatManager="*res://scripts/autoloads/combat_manager.gd"
DeathCounterSystem="*res://scripts/autoloads/death_counter_system.gd"
TriggerEngine="*res://scripts/autoloads/trigger_engine.gd"
TimeManager="*res://scripts/autoloads/time_manager.gd"
EconomyManager="*res://scripts/autoloads/economy_manager.gd"
AlignmentManager="*res://scripts/autoloads/alignment_manager.gd"
SettlementManager="*res://scripts/autoloads/settlement_manager.gd"
BeaconManager="*res://scripts/autoloads/beacon_manager.gd"
FogOfWarManager="*res://scripts/autoloads/fog_of_war_manager.gd"
RespawnManager="*res://scripts/autoloads/respawn_manager.gd"
SaveLoadManager="*res://scripts/autoloads/save_load_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=960
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/vsync/vsync_mode=1

[input]

move_up={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":87,"key_label":0,"unicode":119,"location":0,"echo":false,"script":null)
